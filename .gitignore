# 大二进制 / 可从 ckpt 或录像再生成的产物
*.ckpt
*.ply
*.mp4
*.avi
*.jsonl

# COLMAP Windows 发行版（去官网下，不进库）
tools/COLMAP/

# 原始数据集（照片体积大，源头在手机/Windows 机另有备份）
phone_camera_calibration_imgs/
world_camera_calibration_imgs/
test_scene/
test_scene_processed/
lab_scene_splat_result/

# 每段录像的批量标注帧（process_recording.sh 一条命令可再生成）
lab_result/rec*_wfix/
lab_result/rec*_fixations/

# SAM 分割的可再生成可视化与日志（~45MB；正品是 points.npz + instances.json）
lab_result/segmentation_sam/thumbs/
lab_result/segmentation_sam/preview/
lab_result/segmentation_sam/run.log
lab_result/segmentation_sam/run.err

# 杂项
__pycache__/
*.pyc
__MACOSX/
.DS_Store

